{
  "name": "mathquest-3d",
  "private": true,
  "version": "0.35.0",
  "type": "module",
  "description": "MathQuest 3D - v0.35 Canonical 800：節慶、生態、關係事件、傳送門、機關與戰鬥VFX",
  "scripts": {
    "dev": "vite",
    "build": "npm run art:governance:test && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "audit": "node scripts/run-audit.mjs",
    "simulation:test": "node scripts/run-simulation-tests.mjs",
    "region:test": "node scripts/run-region-production-tests.mjs",
    "region:gameplay:test": "node scripts/run-region-gameplay-tests.mjs",
    "region:gameplay:manifest:export": "node scripts/export-region-gameplay-manifest.mjs",
    "manifest:export": "node scripts/export-production-manifests.mjs",
    "assets:generate": "node scripts/art-pipeline/run-canonical-art-pipeline.mjs --scope=production",
    "runtime:production:test": "node scripts/run-production-runtime-tests.mjs",
    "runtime:production:report": "node scripts/run-production-runtime-tests.mjs --write-report",
    "runtime:manifest:export": "node scripts/export-runtime-production-manifest.mjs",
    "runtime:qa:cdp": "node scripts/runtime-qa-cdp.mjs",
    "runtime:http:v035:test": "node scripts/run-v035-http-smoke.mjs",
    "release:test": "node scripts/run-release-022-tests.mjs",
    "release:manifest:export": "node scripts/export-release-022-manifest.mjs",
    "release:evidence:export": "node scripts/export-release-022-evidence.mjs",
    "traversal:test": "node scripts/run-terrain-traversal-tests.mjs",
    "traversal:evidence:export": "node scripts/export-terrain-traversal-evidence.mjs",
    "assets:environment:generate": "node scripts/art-pipeline/run-canonical-art-pipeline.mjs --scope=environment",
    "environment:life:test": "node scripts/run-environment-life-tests.mjs",
    "life:core:test": "node scripts/run-life-simulation-core-tests.mjs",
    "life:core:evidence:export": "node scripts/export-life-simulation-core-evidence.mjs",
    "village:companion:test": "node scripts/run-village-companion-tests.mjs",
    "companions:generate": "node scripts/art-pipeline/run-canonical-art-pipeline.mjs --scope=companions",
    "village:companion:evidence:export": "node scripts/export-village-companion-evidence.mjs",
    "art:foundation:generate": "node scripts/art-pipeline/build-art-foundation.mjs && node scripts/art-pipeline/build-runtime-atlases.mjs",
    "art:governance:test": "node scripts/run-art-governance-tests.mjs",
    "test:foundation": "npm run art:foundation:generate && npm run art:governance:test && npm run runtime:production:test && npm run village:farm:test && npm run life:core:test && npm run village:companion:test && npm run characters:companions:test && npm run equipment:combat:test && npm run regions:v033:test && npm run interiors:v034:test && npm run events:v035:test",
    "art:pipeline": "node scripts/art-pipeline/run-canonical-art-pipeline.mjs",
    "art:atlases:generate": "node scripts/art-pipeline/build-runtime-atlases.mjs",
    "village:farm:test": "node scripts/run-village-farm-expansion-tests.mjs",
    "characters:companions:test": "node scripts/run-character-companion-v031-tests.mjs",
    "equipment:combat:test": "node scripts/run-equipment-combat-v032-tests.mjs",
    "equipment:generate": "node scripts/art-pipeline/run-canonical-art-pipeline.mjs --scope=equipment",
    "regions:v033:generate": "node scripts/art-pipeline/run-canonical-art-pipeline.mjs --scope=regionsV033",
    "regions:v033:test": "node scripts/run-region-creature-v033-tests.mjs",
    "interiors:v034:generate": "node scripts/art-pipeline/run-canonical-art-pipeline.mjs --scope=interiorsV034 && node scripts/art-pipeline/optimization/meshoptCompressionAudit.mjs",
    "interiors:v034:test": "node scripts/run-interior-tower-v034-tests.mjs",
    "meshopt:v034:audit": "node scripts/art-pipeline/optimization/meshoptCompressionAudit.mjs",
    "events:v035:generate": "node scripts/art-pipeline/run-canonical-art-pipeline.mjs --scope=eventsV035",
    "events:v035:test": "node scripts/run-event-effect-v035-tests.mjs",
    "release:v035:verify": "node scripts/run-final-v035-verification.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/rapier": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "meshoptimizer": "^1.1.1",
    "recharts": "^2.13.3",
    "three": "^0.169.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "basis_universal": "^1.16.4-1",
    "gh-pages": "^6.2.0",
    "postcss": "^8.4.49",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.14",
    "vite": "^8.1.4"
  }
}
